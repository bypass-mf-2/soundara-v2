# Soundara Environment Configuration
# Copy this file to .env and fill in your actual values

# ====================
# SECURITY SETTINGS
# ====================

# JWT Secret Key - Generate a strong random key
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Environment (development or production)
ENVIRONMENT=development

# ====================
# STRIPE SETTINGS
# ====================

# Stripe API Keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Webhook Secret
# Get this from Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ====================
# CORS SETTINGS
# ====================

# Allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://soundara.co,https://www.soundara.co

# ====================
# RATE LIMITING
# ====================

# Rate limits (requests per time period)
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500
RATE_LIMIT_PER_DAY=5000

# ====================
# FILE UPLOAD SETTINGS
# ====================

# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# ====================
# DATABASE (for future use)
# ====================

# PostgreSQL connection string (not used yet, for V2)
# DATABASE_URL=postgresql://user:password@localhost:5432/soundara

# ====================
# REDIS (for future use)
# ====================

# Redis URL for caching and rate limiting (not used yet)
# REDIS_URL=redis://localhost:6379/0

# ====================
# AI GENERATION (for V3)
# ====================

# AI Music Generation API Key (e.g., Stability AI)
# STABILITY_AI_KEY=sk-your-stability-ai-key-here

# ====================
# EXTERNAL SERVICES
# ====================

# Email service (for notifications - future)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ====================
# LOGGING
# ====================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ====================
# DEVELOPMENT ONLY
# ====================

# FFmpeg location (for local development on Windows)
# FFMPEG_PATH=C:\Users\YourUser\Downloads\ffmpeg\bin

# Debug mode (true/false)
DEBUG=true
