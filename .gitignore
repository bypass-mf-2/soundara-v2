# Node dependencies
node_modules/

# React build outputs
frontend/build/

# Backend build (if any)
backend/build/

# SQLite DB (server-only runtime state)
*.db
*.db-journal
*.db-wal
*.db-shm

# JSON backups created by the SQLite migration
*.pre_migration.bak

# Generated demo clips (regenerated from demo_source.mp3 on deploy)
backend/assets/demo_*.wav

# Environment variables
# Ignore backend secrets at the project root
/.env
# Ignore local overrides everywhere
.env.local
# Commit frontend build-time env files (VITE_API_URL etc., no secrets)
!frontend/.env.development
!frontend/.env.production

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# MacOS / Windows system files
.DS_Store
Thumbs.db